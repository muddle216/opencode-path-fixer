{
  "manifest_version": 3,
  "name": "OpenCode Path Fixer",
  "version": "1.0.0",
  "description": "Automatically fixes Windows backslash paths in OpenCode web sessions",
  "permissions": [],
  "host_permissions": ["*://*/*"],
  "content_scripts": [{
    "matches": ["*://*/*"],
    "js": ["path-utils.js", "content.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenCode Path Fixer"
  }
}